# Excel File Paths
# For development, use ./Examples directory
# For production, use network drive paths
EXCEL_BASE_PATH=./Examples
COMPANIES_FILE_PATH=./Examples/companies.xlsx
NEXT_PUBLIC_DEFAULT_COMPANY=VANCE

# Production paths (uncomment and modify for production)
# EXCEL_BASE_PATH=S:/PBIData/NetDoc/Manual
# COMPANIES_FILE_PATH=S:/PBIData/Biztech/companies.xlsx

# Authentication
# JWT_SECRET is REQUIRED when auth is enabled — sessions are signed with it.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-secret-key-change-in-production-use-long-random-string
JWT_EXPIRES_IN=7d
AUTH_DB_PATH=./data/auth.db
# Create users with: npm run users -- add <username> --role admin

# Fallback admin login, used ONLY when the auth database is unavailable.
# Leave these unset to disable fallback login entirely (recommended once
# the auth database is set up).
# FALLBACK_ADMIN_USERNAME=admin
# FALLBACK_ADMIN_PASSWORD=pick-a-strong-password

# Application Settings
NEXT_PUBLIC_APP_NAME=Client Data Management System

# Cache Settings (milliseconds)
EXCEL_CACHE_TTL=300000

# Logging
LOG_LEVEL=info

# Set to true to bypass login entirely (e.g. during a migration window)
DISABLE_AUTH=false
